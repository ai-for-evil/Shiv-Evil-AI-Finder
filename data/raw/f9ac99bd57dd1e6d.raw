ands/reuters/\"},\"showPage\":true}},\"canonicalSite\":\"aolnews\",\"categoryLabel\":\"World\",\"isOpinion\":false,\"isShoppable\":false,\"commentsAllowed\":true,\"commerceArticleType\":false,\"contentCover\":{\"cover\":{\"type\":\"image\",\"headline\":\"Italian police freeze cash from AI-voice scam that targeted business leaders\",\"caption\":\"\",\"credit\":\"\",\"size\":{\"original\":{\"width\":800,\"height\":534,\"url\":\"https://media.zenfs.com/en/aol_reuters_29/26948eb72e7623407a81d8c7047188d8\"},\"resized\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/8PfkASzLuZl6Pfqfmzr29A--/YXBwaWQ9aGlnaGxhbmRlcjt3PTEyNDI7aD04Mjk-/https://media.zenfs.com/en/aol_reuters_29/26948eb72e7623407a81d8c7047188d8\",\"width\":800,\"height\":534},\"lightbox\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/iQoJmSBQAQ6tTECuQHgz6w--/YXBwaWQ9aGlnaGxhbmRlcjt3PTE2MDA7aD0xMDY4/https://media.zenfs.com/en/aol_reuters_29/26948eb72e7623407a81d8c7047188d8\",\"width\":800,\"height\":534}},\"isRelatedContent\":true,\"showBylineOnTop\":true,\"provider\":{\"name\":\"Reuters\",\"ref\":\"b00a8ce1-9f10-347a-97a0-009718063130\",\"url\":{\"external\":true,\"link\":\"https://www.reuters.com/\"},\"logo\":{\"size\":{\"original\":{\"alt\":\"\",\"height\":100,\"tag\":\"size=original\",\"url\":\"https://s.yimg.com/os/creatr-uploaded-images/2020-11/62e21440-2fbd-11eb-95ff-5673fa3d2f9f\",\"width\":428},\"resized\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/Hm40uTzmW5o.e4WmQkG_qQ--/YXBwaWQ9aGlnaGxhbmRlcjt3PTM0MjtoPTgw/https://s.yimg.com/os/creatr-uploaded-images/2020-11/62e21440-2fbd-11eb-95ff-5673fa3d2f9f\",\"width\":171,\"height\":40}}},\"darkLogo\":{\"size\":{\"original\":{\"alt\":\"\",\"height\":100,\"tag\":\"size=original\",\"url\":\"https://s.yimg.com/os/creatr-uploaded-images/2020-11/97e12050-2fbd-11eb-b7ff-09d0ec37765f\",\"width\":428},\"resized\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/enHHfctgUNHmVWtwoUavsQ--/YXBwaWQ9aGlnaGxhbmRlcjt3PTM0MjtoPTgw/https://s.yimg.com/os/creatr-uploaded-images/2020-11/97e12050-2fbd-11eb-b7ff-09d0ec37765f\",\"width\":171,\"height\":40}}},\"coverLogo\":{\"size\":{\"original\":{\"alt\":\"\",\"height\":100,\"tag\":\"size=original\",\"url\":\"https://s.yimg.com/os/creatr-uploaded-images/2020-11/4852ea50-2fbd-11eb-aeff-43cddf2f474f\",\"width\":428},\"resized\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/fJMmj5R.RHDX3lQg6innDw--/YXBwaWQ9aGlnaGxhbmRlcjt3PTM0MjtoPTgw/https://s.yimg.com/os/creatr-uploaded-images/2020-11/4852ea50-2fbd-11eb-aeff-43cddf2f474f\",\"width\":171,\"height\":40}}},\"useLogo\":true,\"providerId\":\"aol_reuters_29\"},\"config\":{\"videoPosition\":\"top\"}},\"enableLead\":\"DEFAULT\"},\"contentImages\":{\"photos\":[],\"photosCount\":0,\"preload\":[{\"href\":\"https://s.yimg.com/ny/api/res/1.2/8PfkASzLuZl6Pfqfmzr29A--/YXBwaWQ9aGlnaGxhbmRlcjt3PTEyNDI7aD04Mjk-/https://media.zenfs.com/en/aol_reuters_29/26948eb72e7623407a81d8c7047188d8\",\"as\":\"image\"}],\"primaryImage\":{\"original\":{\"width\":800,\"height\":534,\"url\":\"https://media.zenfs.com/en/aol_reuters_29/26948eb72e7623407a81d8c7047188d8\"},\"resized\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/8PfkASzLuZl6Pfqfmzr29A--/YXBwaWQ9aGlnaGxhbmRlcjt3PTEyNDI7aD04Mjk-/https://media.zenfs.com/en/aol_reuters_29/26948eb72e7623407a81d8c7047188d8\",\"width\":800,\"height\":534},\"lightbox\":{\"url\":\"https://s.yimg.com/ny/api/res/1.2/iQoJmSBQAQ6tTECuQHgz6w--/YXBwaWQ9aGlnaGxhbmRlcjt3PTE2MDA7aD0xMDY4/https://media.zenfs.com/en/aol_reuters_29/26948eb72e7623407a81d8c7047188d8\",\"width\":800,\"height\":534}},\"shareImage\":{\"width\":800,\"height\":534,\"url\":\"https://s.yimg.com/os/en/aol_reuters_29/26948eb72e7623407a81d8c7047188d8\"}},\"contentIdentifiers\":{\"readMoreList\":\"\",\"enableTableOfContents\":false,\"hideAdTypes\":[],\"headerSectionName\":\"\",\"hostedType\":\"hosted\",\"isBrandedContent\":false,\"isCreatorContent\":false,\"isNewsletterArticle\":false,\"isOriginalContent\":false,\"isPersonalFinanceArticle\":false,\"isReadMoreListOverridden\":false,\"isSeamlessBypass\":false,\"isSponsoredContent\":false,\"sponsoredTagContent\":false,\"isSportsProviderContent\":false,\"isSportsPolarisVideoIneligible\":false,\"isNetworkSportsContent\":false,\"isUncrownedArticle\":false,\"isWalmartSubnav\":false,\"presentation\":null,\"showImageCredit\":true},\"contentSummaries\":{\"aiSummary\":[{\"type\":\"text\",\"value\":\"Italian police froze nearly one million euros wired to a foreign bank account by a businessman who fell victim to an artificial intelligence scam mimicking the voice of Italian Defence Minister Guido Crosetto.\"},{\"type\":\"text\",\"value\":\"Prominent Italian business figures, including Giorgio Armani and Patrizio Bertelli, were targeted in the scam, but only Massimo Moratti, former owner of Inter Milan, sent the requested funds, which have now been located in the Netherlands.\"},{\"type\":\"text\",\"value\":\"The fraudsters posed as officials from the defence ministry, used AI technology to simulate Crosetto's voice, and convinced Moratti to transfer the money under the mistaken belief that he would be reimbursed by the Bank of Italy.\"}],\"summary\":\"Italian police have found and frozen nearly one million euros ($1.04 million) that was wired to a foreign bank account by a leading businessman after he fell victim to an artificial intelligence scam, officials said on Wednesday. Fraudsters used AI to mimic the voice of Italian Defence Minister Guido Crosetto, making calls that claimed to seek urgent financial assistance for the release of kidnapped Italian journalists in the Middle East. Some of Italy's most prominent business figures, includin\"},\"contentTags\":{\"normalizedTags\":{\"ymedia\":{\"signal\":[\"summary_source\"],\"provider_id\":[\"aol_reuters_29\"],\"category\":[\"100000003\",\"100000002\"],\"provider_category\":[\"OLUSTECHMO_iptc\"],\"hosted\":[\"yes\"]},\"aolnews\":{\"region\":[\"us\"]},\"aolhomepage\":{\"region\":[\"us\"]},\"aolfrontpage\":{\"region\":[\"us\"]},\"editorialTags\":[]},\"salientEntities\":[],\"sportsGameCategory\":\"\",\"sportsTeamIds\":\"\"},\"contentI13n\":{\"redirectMetaData\":{\"originalId\":null,\"newId\":\"fce23218-33f8-39f7-a47d-98022fb325d3\"},\"uuid\":\"fce23218-33f8-39f7-a47d-98022fb325d3\",\"pct\":\"story\",\"spaceId\":1197803369,\"spaceIds\":{},\"type\":\"story\",\"videoPosition\":\"top\"},\"contentType\":\"story\",\"contentVideoInfo\":{\"hasYahooVideo\":false,\"hasVideoTranscript\":false,\"videoTranscript\":null},\"dates\":{\"publishDate\":{\"utc\":\"Wed, 12 Feb 2025 19:16:16 GMT\",\"iso\":\"2025-02-12T19:16:16.000Z\",\"format\":\"February 12, 2025 at 2:16 PM\",\"timestamp\":1739387776000},\"modifiedDate\":{\"utc\":\"Wed, 12 Feb 2025 19:16:16 GMT\",\"iso\":\"2025-02-12T19:16:16.000Z\",\"format\":\"February 12, 2025 at 2:16 PM\",\"timestamp\":1739387776000},\"displayDate\":{\"utc\":\"Wed, 12 Feb 2025 19:16:16 GMT\",\"iso\":\"2025-02-12T19:16:16.000Z\",\"format\":\"February 12, 2025 at 2:16 PM\",\"timestamp\":1739387776000},\"modifiedDateIsGreater\":false},\"entities\":[{\"term\":\"WIKIID:Guido_Crosetto\",\"label\":\"Guido Crosetto\",\"capAbtScore\":\"0.989\",\"metaData\":[{\"visible\":\"false\"}],\"startchar\":331,\"endchar\":344,\"specialParentTags\":[],\"instanceParentTags\":[]},{\"term\":\"WIKIID:Massimo_Moratti\",\"label\":\"Massimo Moratti\",\"capAbtScore\":\"0.976\",\"metaData\":[{\"visible\":\"false\"}],\"startchar\":697,\"endchar\":711,\"specialParentTags\":[],\"instanceParentTags\":[]},{\"term\":\"WIKIID:Artificial_intelligence\",\"label\":\"artificial intelligence\",\"capAbtScore\":\"0.917\",\"metaData\":[{\"visible\":\"false\"}],\"startchar\":197,\"endchar\":219,\"specialParentTags\":[\"title\"],\"instanceParentTags\":[]},{\"term\":\"WIKIID:Inter_Milan\",\"label\":\"Inter Milan\",\"capAbtScore\":\"0.902\",\"metaData\":[{\"visible\":\"false\"}],\"startchar\":746,\"endchar\":756,\"specialParentTags\":[],\"instanceParentTags\":[]},{\"term\":\"\",\"label\":\"Italian police\",\"capAbtScore\":\"0.883\",\"metaData\":[{\"visible\":\"false\"}],\"startchar\":26,\"endchar\":39,\"specialParentTags\":[],\"instanceParentTags\":[]},{\"term\":\"WIKIID:Patrizio_Bertelli\",\"label\":\"Patrizio Bertelli\",\"capAbtScore\":\"0.857\",\"metaData\":[{\"visible\":\"false\"}],\"startchar\":603,\"endchar\":619,\"specialParentTags\":[],\"instanceParentTags\":[]},{\"term\":\"WIKIID:Giorgio_Armani\",\"label\":\"Giorgio Armani\",\"capAbtScore\":\"0.803\",\"metaData\":[{\"visible\":\"false\"}],\"startchar\":567,\"endchar\":580,\"specialParentTags\":[],\"instanceParentTags\":[]},{\"term\":\"\",\"label\":\"Italian journalists\",\"capAbtScore\":\"0.744\",\"metaData\":[{\"visible\":\"false\"}],\"startchar\":438,\"endchar\":456,\"specialParentTags\":[],\"instanceParentTags\":[]},{\"term\":\"YCT:001000667\",\"score\":\"0.692308\",\"label\":\"Crime \u0026 Justice\"},{\"term\":\"YMEDIA:CATEGORY=100000003\",\"score\":\"1.0\",\"label\":\"\"},{\"term\":\"YMEDIA:CATEGORY=100000002\",\"score\":\"1.0\",\"label\":\"\"}],\"liveBlogUpdatedTime\":{},\"readTime\":2,\"personalFinance\":{},\"liveBlog\":{\"totalCount\":0,\"formattedStartTime\":{}},\"seoMeta\":{\"appLinks\":{\"al:android:app_name\":\"Aol App\",\"al:android:package\":\"com.aol.mobile.aolapp\",\"al:ios:app_name\":\"Aol App\",\"al:ios:app_store_id\":\"646100661\"},\"twitterTags\":{\"twitter:site\":\"@AOL\",\"twitter:dnt\":\"on\"},\"ogTags\":{\"og:type\":\"article\"},\"canonicalUrl\":\"https://www.aol.com/news/italian-police-freeze-cash-ai-191616630.html\",\"nativeUrl\":\"https://www.aol.com/italian-police-freeze-cash-ai-191616630.html\",\"seoTitle\":\"\",\"searchNoIndex\":false,\"title\":\"Italian police freeze cash from AI-voice scam that targeted business leaders\",\"subheadline\":\"\",\"socialHeadline\":\"\",\"keywords\":\"Guido Crosetto, Massimo Moratti, artificial intelligence, Inter Milan, Italian police, Patrizio Bertelli, Giorgio Armani, Italian journalists\",\"providerContentUrl\":\"https://finance.yahoo.com/news/italian-police-freeze-cash-ai-191616297.html\",\"previewLink\":null,\"clickThroughUrl\":\"https://www.aol.com/italian-police-freeze-cash-ai-191616630.html\",\"homepageUrl\":\"https://www.aol.com/italian-police-freeze-cash-ai-191616630.html\",\"seamlessUrl\":\"https://www.yahoo.com/italian-police-freeze-cash-ai-191616630.html\"},\"siteSections\":{\"sectionItems\":[],\"sectionContentCategoryPath\":\"\"},\"secondaryTypes\":[],\"storyAtoms\":[{\"type\":\"text\",\"content\":\"MILAN (Reuters) - Italian police have found and frozen nearly one million euros ($1.04 million) that was wired to a foreign bank account by a leading businessman after he fell victim to an artificial intelligence scam, officials said on Wednesday.\",\"length\":247,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"Fraudsters used AI to mimic the voice of Italian Defence Minister Guido Crosetto, making calls that claimed to seek urgent financial assistance for the release of kidnapped Italian journalists in the Middle East.\",\"length\":212,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"Some of Italy\u0026#39;s most prominent business figures, including fashion designer Giorgio Armani and Prada co-founder Patrizio Bertelli, were targeted, prosecutors in Milan said earlier this week. However, only Massimo Moratti, the former owner of soccer club Inter Milan, was believed to have sent the requested funds.\",\"length\":317,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"Officials said they thought it would be hard to retrieve the missing funds, but on Wednesday they revealed the cash had been located to the Netherlands.\",\"length\":152,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"\u0026quot;I\u0026#39;m very pleased that the money fraudulently taken from an entrepreneur, using my falsified voice and name, has been traced to a Dutch account and completely frozen,\u0026quot; Crosetto said on X. \u0026quot;Excellent work by the magistrates and the police forces.\u0026quot;\",\"length\":270,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"There was no immediate comment from Moratti, who had transferred two payments totalling almost one million euros, under the mistaken belief that he would be reimbursed by the Bank of Italy, sources familiar with the case have said.\",\"length\":231,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"Moratti filed a legal complaint last week after realizing he had been duped. \u0026quot;It all seemed real. They were good. It could happen to anyone,\u0026quot; he told Italian daily La Repubblica at the weekend.\",\"length\":203,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"The scam involved fraudsters posing as officials from the defence ministry, with calls that appeared to originate from government offices in Rome. They then passed the phone to a man they said was Crosetto, who asked for money, saying the government could not be seen to be behind the transactions.\",\"length\":298,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"The defence minister has said they used AI technology to convincingly simulate his voice. ($1 = 0.9615 euros)\",\"length\":109,\"tagName\":\"p\"},{\"type\":\"text\",\"content\":\"(Reporting by Angelo Amante; Editing by Crispian Balmer)\",\"length\":56,\"tagName\":\"p\"}]}},\"schema\":{\"default\":{\"@context\":\"http://schema.org\",\"@type\":\"NewsArticle\",\"mainEntityOfPage\":\"https://www.aol.com/italian-police-freeze-cash-ai-191616630.html\",\"headline\":\"Italian police freeze cash from AI-voice scam that targeted business leaders\",\"datePublished\":\"2025-02-12T19:16:16.000Z\",\"dateModified\":\"2025-02-12T19:16:16.000Z\",\"keywords\":[\"Guido Crosetto\",\"Massimo Moratti\",\"artificial intelligence\",\"Inter Milan\",\"Italian police\",\"Patrizio Bertelli\",\"Giorgio Armani\",\"Italian journalists\"],\"description\":\"Italian police have found and frozen nearly one million euros ($1.04 million) that was wired to a foreign bank account by a leading businessman after he fell...\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"AOL\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://s.yimg.com/cv/apiv2/hlogos/aol_Light.png\",\"width\":151,\"height\":100},\"url\":\"https://www.aol.com\"},\"author\":{\"@type\":\"Organization\",\"name\":\"Reuters\",\"url\":\"https://www.reuters.com/\",\"logo\":{\"@type\":\"ImageObject\",\"width\":428,\"height\":100,\"url\":\"https://s.yimg.com/os/creatr-uploaded-images/2020-11/62e21440-2fbd-11eb-95ff-5673fa3d2f9f\"}},\"creator\":{\"@type\":\"Organization\",\"name\":\"Reuters\",\"url\":\"https://www.reuters.com/\",\"logo\":{\"@type\":\"ImageObject\",\"width\":428,\"height\":100,\"url\":\"https://s.yimg.com/os/creatr-uploaded-images/2020-11/62e21440-2fbd-11eb-95ff-5673fa3d2f9f\"}},\"provider\":{\"@type\":\"Organization\",\"name\":\"Reuters\",\"url\":\"https://www.reuters.com/\",\"logo\":{\"@type\":\"ImageObject\",\"width\":428,\"height\":100,\"url\":\"https://s.yimg.com/os/creatr-uploaded-images/2020-11/62e21440-2fbd-11eb-95ff-5673fa3d2f9f\"}},\"image\":{\"@type\":\"ImageObject\",\"url\":\"https://s.yimg.com/ny/api/res/1.2/iQoJmSBQAQ6tTECuQHgz6w--/YXBwaWQ9aGlnaGxhbmRlcjt3PTE2MDA7aD0xMDY4/https://media.zenfs.com/en/aol_reuters_29/26948eb72e7623407a81d8c7047188d8\",\"height\":534,\"width\":800},\"thumbnailUrl\":\"https://s.yimg.com/ny/api/res/1.2/iQoJmSBQAQ6tTECuQHgz6w--/YXBwaWQ9aGlnaGxhbmRlcjt3PTE2MDA7aD0xMDY4/https://media.zenfs.com/en/aol_reuters_29/26948eb72e7623407a81d8c7047188d8\"}}},\"type\":0},\"index\":0},\"articleChangeCounter\":0,\"renderedArticles\":[\"$48:props:children:1:props:children:0:props:children:0:props:children:props:value:isActive:article\"],\"hydratedArticles\":[],\"pendingArticles\":[{\"uuid\":\"dbd7a96e-fc02-4bd5-aab2-67e688ca732f\",\"title\":\"We scrolled Walmart's style section — these pieces are selling out fast\",\"href\":\"/shopping/deals/article/we-scrolled-walmarts-style-section--these-pieces-are-selling-out-fast-183925643.html\",\"commentsAllowed\":true},{\"uuid\":\"03b81720-4c98-4bc1-beb8-eb1aad7e46d8\",\"title\":\"We found the best turtlenecks to keep you warm during the polar vortex — and they're all less than $40\",\"href\":\"/shopping/style/article/we-found-the-best-turtlenecks-to-keep-you-warm-during-the-polar-vortex--and-theyre-all-less-than-40-153122592.html\",\"commentsAllowed\":true},{\"uuid\":\"97d77535-bf3a-4a39-b12f-4d96cc152d58\",\"title\":\"Where to buy on-sale outdoor cushions to replace your old dingy ones\",\"href\":\"/shopping/deals/article/where-to-buy-on-sale-outdoor-cushions-to-replace-your-old-dingy-ones-183903382.html\",\"commentsAllowed\":true}]},\"children\":\"$L4c\"}]}],\"$L4d\"]}],\"$L4e\"]}],\"$L4f\"]}]\n"])</script><script>self.__next_f.push([1,"50:I[497,[\"6841\",\"static/chunks/f08fe478-f8e3e9a68a45c6ce.js\",\"3473\",\"static/chunks/891cff7f-f75a1a6240d4bcd3.js\",\"3296\",\"static/chunks/3296-a08a8794096a21d9.js\",\"1623\",\"static/chunks/1623-487798606af878ee.js\",\"4974\",\"static/chunks/4974-6e948ce6b7c77bb7.js\",\"5739\",\"static/chunks/5739-db2a773e4309693e.js\",\"2756\",\"static/chunks/2756-c3647f96262111cd.js\",\"631\",\"static/chunks/631-47d85c0d056d0a74.js\",\"8571\",\"static/chunks/8571-94b80ec9efef6d6b.js\",\"8608\",\"static/chunks/app/article/%5B%5B...parts%5D%5D/page-fa9ffae3a730fab3.js\"],\"SeamlessArticles\"]\n51:T469,"])</script><script>self.__next_f.push([1,"\u003cdiv class=\"maas-item\"\u003e\u003cdiv id=m class=\"em-module col-span-full !mb-0 \"\u003e\u003cdiv class=\"m-gam__container m-gam__container--stacked m-gam__container--top_right_stack t-grid\"\u003e\u003cdiv style=min-height:600px;min-width:300px id=LREC_top_right_0 class=\"m-gam m-gam--stack-top t-grid\" data-config='{\"enabled\":true,\"id\":\"LREC_top_right_0\",\"region\":\"index\",\"kvs\":{\"loc\":\"top_right_a\"},\"stackGroup\":\"top_right_stack\",\"path\":\"/22888152279/us/aol/ros/dt/us_aol_ros_dt_as_top_right_a\",\"size\":[[300,250]]}'\u003e\u003cdiv class=m-gam__placeholder style=height:600px;width:300px\u003e\u003cp\u003eAdvertisement\u003c/p\u003e\u003c/div\u003e\